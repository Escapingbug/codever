{
  "name": "codever",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram-driven Claude Code remote agent",
  "type": "module",
  "bin": {
    "codever": "./bin/codever.js",
    "codever-mcp": "./dist/mcp/stdio.js"
  },
  "scripts": {
