    "chalk": "^5.3.0",
    "conf": "^12.0.0",
    "grammy": "^1.30.0",
    "https-proxy-agent": "^9.0.0",
    "undici": "^8.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": ">=20",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
